# =========================================================================
# AI Trading System — environment example. Copy to .env and fill in.
# NEVER commit the real .env file.
# =========================================================================

# ---- App / runtime ----
APP_ENV=development                 # development | production
EXECUTION_MODE=paper                # paper | demo | approval | live
AUTO_MODE_ENABLED=false             # Live auto mode disabled by default
HEDGING_ENABLED=false               # Hedging OFF by default
TIMEZONE=Asia/Dubai

# ---- Dashboard / API auth ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong     # use a strong password; hashed at rest
JWT_SECRET=change_me_random_long_secret
SESSION_SECRET=change_me_random_long_secret
PUBLIC_BASE_URL=http://VPS_IP       # later: https://your-domain

# ---- Capital.com broker ----
CAPITAL_ENVIRONMENT=demo            # demo | live  (start with demo)
CAPITAL_API_KEY=
CAPITAL_IDENTIFIER=                 # account login (email)
CAPITAL_PASSWORD=
CAPITAL_DEMO_BASE_URL=https://demo-api-capital.backend-capital.com
CAPITAL_LIVE_BASE_URL=https://api-capital.backend-capital.com
CAPITAL_WS_URL=wss://api-streaming-capital.backend-capital.com/connect

# ---- AI providers ----
AI_PROVIDER=claude                  # claude | openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
OPENAI_API_KEY=                     # optional second opinion later
AI_MIN_CONFIDENCE=70

# ---- Risk engine defaults (AED) ----
ACCOUNT_START_CAPITAL=5000
MAX_ACTIVE_TRADES=2
MAX_RISK_PER_TRADE=50
MAX_COMBINED_OPEN_RISK=100
MAX_TRADES_PER_DAY=3
DAILY_MAX_LOSS=150
WEEKLY_MAX_LOSS=400
STOP_AFTER_N_LOSSES=2
MIN_RISK_REWARD=2.0

# ---- News / calendar provider ----
NEWS_API_KEY=

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=change_me_strong
DATABASE_URL=postgresql+psycopg://trading:change_me_strong@db:5432/trading

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
